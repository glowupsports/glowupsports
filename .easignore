# EAS Build Ignore File
# Only include Expo app source + assets

# Node / package managers
node_modules/
npm-debug.log
yarn-error.log
pnpm-lock.yaml
package-lock.json

# Server / Backend (not needed for mobile build)
server/
server_dist/

# Static build (server-side Expo bundles, not needed for native build)
static-build/

# User uploads (not needed for app build)
uploads/

# Native directories (CNG/Prebuild generates these)
/android
/ios

# Expo / Metro
.expo/
.expo-shared/
web-build/
dist/
.metro-cache/

# Git
.git/
.gitignore

# Replit specific
.replit
replit.nix
.cache/
.local/
.upm/
.config/
.env
.env.*
.deployignore

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
logs/
*.log
*.hprof
/tmp/

# Tests / Coverage
__tests__/
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Attachments / Assets not needed
attached_assets/
screenshots/
docs/

# Database / Migrations (handled server-side)
drizzle/
migrations/

# Build scripts
scripts/

# Misc
*.md
!README.md
*.pdf
.prettierrc
.eslintrc*
vitest.config.ts
