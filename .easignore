# EAS Build Ignore File
# Only include Expo app source + assets

# Node / package managers
node_modules/
npm-debug.log
yarn-error.log
pnpm-lock.yaml

# Server / Backend (not needed for mobile build)
server/

# Native directories (CNG/Prebuild generates these)
/android
/ios

# Expo / Metro
.expo/
.expo-shared/
web-build/
dist/

# Git
.git/
.gitignore

# Replit specific
.replit
replit.nix
.cache/
.local/
.upm/
.config/
.env
.env.*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
logs/
*.log
*.hprof

# Tests / Coverage
__tests__/
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Attachments / Assets not needed
attached_assets/
screenshots/
docs/

# Database / Migrations (handled server-side)
drizzle/
drizzle.config.ts
migrations/

# Build artifacts (Replit web deployment, not needed for native)
static-build/
server_dist/

# Server uploads (user-uploaded files, handled server-side)
uploads/

# GitHub
.github/

# Misc
*.md
!README.md
.prettierrc
.eslintrc*
tsconfig*.json
vitest.config.ts
eslint.config.js
