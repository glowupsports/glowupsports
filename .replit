entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["imagemagick"]

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 23636
externalPort = 80

[[ports]]
localPort = 23637
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["resend:1.0.0", "google-calendar:1.0.0", "javascript_openai_ai_integrations:2.0.0", "stripe:1.0.0", "revenuecat:1.0.0", "github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OTA Push"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Push"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c \"(lsof -ti:8081 2>/dev/null | xargs -r kill -9) || true; npm run server:dev & npm run expo:dev\""

[[workflows.workflow]]
name = "OTA Push"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OTA_MESSAGE=\"Tasks #856-#861: Android chat blur fix, theme editor on player card, tonal theme system + 8 presets, theme gallery preview\" bash scripts/ota-push.sh"

[[workflows.workflow]]
name = "GitHub Push"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "GIT_ASKPASS='' GIT_TERMINAL_PROMPT=0 git remote set-url github \"https://glowupsports:$GITHUB_PAT@github.com/glowupsports/glowupsports.git\" 2>/dev/null || git remote add github \"https://glowupsports:$GITHUB_PAT@github.com/glowupsports/glowupsports.git\" && git push github main 2>&1"

[userenv]

[userenv.shared]
EXPO_PUBLIC_DOMAIN = "glow-up-sports--ltvjeugd.replit.app"
EXPO_PUBLIC_SENTRY_DSN = "https://e16898b13be10a8c4d1d87c59199791d@o4510895209119744.ingest.us.sentry.io/4510895220260864"
REVENUECAT_PROJECT_ID = "projdff97f8a"
REVENUECAT_TEST_STORE_APP_ID = "app8a91c268b5"
REVENUECAT_APPLE_APP_STORE_APP_ID = "app65821515b2"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "appf48c7ffc35"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_cybUCGcuhpEljjcgSnRLyDltgtH"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_ibBPORTiJtlHBlUfnrBKRIPZket"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_gLtMVeBOTgpDjhtBXnOXJbLImGW"

[userenv.development]
EXPO_PUBLIC_ENV = "development"
OTA_MESSAGE = "Fix GLOW_2 display name, Skill Radar from pillar mastery data"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
