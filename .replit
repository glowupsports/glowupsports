entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["imagemagick"]

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 9999
externalPort = 3002

[[ports]]
localPort = 23636
externalPort = 3003

[[ports]]
localPort = 23637
externalPort = 4200

[[ports]]
localPort = 23638
externalPort = 3001

[[ports]]
localPort = 23639
externalPort = 5173

[[ports]]
localPort = 23640
externalPort = 6000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["resend:1.0.0", "google-calendar:1.0.0", "javascript_openai_ai_integrations:2.0.0", "stripe:1.0.0", "revenuecat:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev & npm run expo:dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

